# ── Public hosting (you deploy once; visitors just open the URL) ─
DOMAIN=                   # Your domain, e.g. files.example.com — point its A record to your server
APP_SECRET=               # Random 32+ char string for session signing

# ── Database ───────────────────────────────────────────────────
MYSQL_PASSWORD=           # Strong password for the app database user
MYSQL_ROOT_PASSWORD=      # Strong password for the MySQL root user

# ── Admin (optional — file sharing works without login) ─────────
OWNER_EMAIL=              # First registered user with this email gets admin role

# ── Server ─────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0